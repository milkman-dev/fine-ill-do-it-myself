  "tokenColors": [

    // ─── Comments ─────────────────────────────────────────────────────────────
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block",
        "comment.line",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5C6370",
        "fontStyle": "italic"
      }
    },

    // ─── Declaration keywords (def, func, class, let, const, import…) ─────────
    {
      "name": "Declaration keywords",
      "scope": [
        "keyword",
        "keyword.other",
        "storage.type"
      ],
      "settings": { "foreground": "#61AFEF" }
    },
    // Storage modifiers (public, static, readonly…) — italic to de-emphasize
    {
      "name": "Storage modifiers",
      "scope": [ "storage.modifier" ],
      "settings": { "foreground": "#61AFEF", "fontStyle": "italic" }
    },
    // Control-flow keywords override the declaration rule above via specificity
    {
      "name": "Control-flow keywords (return, if, for, while, break…)",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": { "foreground": "#D291FF" }
    },
    // Import / export / from — more specific than keyword.control, so stays blue
    {
      "name": "Import / export / from keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.import.python",
        "keyword.control.from.python",
        "keyword.control.import.js",
        "keyword.control.export.js",
        "keyword.control.from.js",
        "keyword.control.import.ts",
        "keyword.control.export.ts",
        "keyword.control.from.ts",
        "keyword.control.import.jsx",
        "keyword.control.export.jsx",
        "keyword.control.import.tsx",
        "keyword.control.export.tsx"
      ],
      "settings": { "foreground": "#61AFEF" }
    },

    // ─── Operators ────────────────────────────────────────────────────────────
    {
      "name": "Operators",
      "scope": [ "keyword.operator" ],
      "settings": { "foreground": "#ABB2BF" }
    },

    // ─── Function and method names ────────────────────────────────────────────
    {
      "name": "Function and method names",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#E5D0A1" }
    },

    // ─── Types, classes, interfaces ───────────────────────────────────────────
    {
      "name": "Type names, classes, interfaces, builtins",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class",
        "support.type.builtin",
        "support.type.primitive",
        "keyword.type"
      ],
      "settings": { "foreground": "#6EC9A8" }
    },

    // ─── Strings ─────────────────────────────────────────────────────────────
    // punctuation.definition.string is NOT in the Punctuation rule — quotes
    // inherit this orange so the whole string is one uniform color.
    {
      "name": "String literals",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple"
      ],
      "settings": { "foreground": "#D19A66" }
    },
    // Template/embedded delimiters ${ } — pink to mark code-in-string boundary
    {
      "name": "Template and embedded expression delimiters",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": { "foreground": "#D291FF" }
    },
    // Code inside ${ } resets to normal foreground
    {
      "name": "Template expression body",
      "scope": [
        "meta.template.expression.js",
        "meta.template.expression.ts",
        "meta.template.expression.jsx",
        "meta.template.expression.tsx"
      ],
      "settings": { "foreground": "#ABB2BF" }
    },
    // Escape sequences and regex — golden, distinct from string orange
    {
      "name": "String escape sequences and regex",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp keyword.operator",
        "string.regexp punctuation.definition"
      ],
      "settings": { "foreground": "#E5C07B" }
    },

    // ─── Numbers ──────────────────────────────────────────────────────────────
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": { "foreground": "#98C379" }
    },

    // ─── Constants and booleans ───────────────────────────────────────────────
    {
      "name": "Constants and booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none.python",
        "constant.language.nullptr.cpp",
        "variable.language.null"
      ],
      "settings": { "foreground": "#98C379" }
    },

    // ─── Variables ────────────────────────────────────────────────────────────
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.property"
      ],
      "settings": { "foreground": "#B0E0E6" }
    },
    // Parameters — same pale cyan as variables, italic to distinguish
    {
      "name": "Function parameters",
      "scope": [ "variable.parameter" ],
      "settings": { "foreground": "#B0E0E6", "fontStyle": "italic" }
    },

    // ─── Object / dict keys ───────────────────────────────────────────────────
    {
      "name": "Object keys",
      "scope": [
        "meta.object-literal.key",
        "meta.object.member string.quoted",
        "support.type.property-name",
        "string.quoted.double.json",
        "string.quoted.single.json"
      ],
      "settings": { "foreground": "#D19A66" }
    },

    // ─── Punctuation — separators, terminators, accessors ────────────────────
    // Note: punctuation.definition.string intentionally excluded (inherits string
    // orange); punctuation.section/meta.brace handled below as brackets.
    {
      "name": "Punctuation (separators, terminators, accessors)",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor"
      ],
      "settings": { "foreground": "#ABB2BF" }
    },
    {
      "name": "Operators (logical, comparison, assignment)",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.increment",
        "keyword.operator.decrement",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": { "foreground": "#D9E0EE" }
    },
    // Brackets and braces — fluorescent yellow
    {
      "name": "Brackets and braces",
      "scope": [
        "punctuation.section",
        "meta.brace.round",
        "meta.brace.curly",
        "meta.brace.square",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end",
        "punctuation.definition.arguments.begin",
        "punctuation.definition.arguments.end",
        "punctuation.brackets.round",
        "punctuation.brackets.curly",
        "punctuation.brackets.square"
      ],
      "settings": { "foreground": "#E5D0A1" }
    },

    // ─── Import paths and module names ────────────────────────────────────────
    {
      "name": "Import paths and module names",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module",
        "string.quoted.double.import",
        "string.quoted.single.import"
      ],
      "settings": { "foreground": "#D19A66" }
    },

    // ─── Decorators and annotations ───────────────────────────────────────────
    {
      "name": "Decorators and annotations",
      "scope": [
        "entity.name.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#C678DD" }
    },

    // ─── HTML / JSX tags ─────────────────────────────────────────────────────
    {
      "name": "HTML/JSX tag names",
      "scope": [ "entity.name.tag" ],
      "settings": { "foreground": "#E06C75" }
    },
    {
      "name": "HTML/JSX attributes",
      "scope": [ "entity.other.attribute-name" ],
      "settings": { "foreground": "#E5D0A1" }
    },

    // ─── Invalid / deprecated ─────────────────────────────────────────────────
    {
      "name": "Invalid / deprecated",
      "scope": [ "invalid", "invalid.deprecated" ],
      "settings": { "foreground": "#E06C75", "fontStyle": "strikethrough" }
    },

    // ═══ Language-specific ════════════════════════════════════════════════════

    // ─── Python ───────────────────────────────────────────────────────────────
    {
      "name": "Python - builtins (len, print, range…)",
      "scope": [ "support.function.builtin.python" ],
      "settings": { "foreground": "#E5D0A1" }
    },
    {
      "name": "Python - self / cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": { "foreground": "#B0E0E6", "fontStyle": "italic" }
    },
    {
      "name": "Python - exception types",
      "scope": [ "support.type.exception.python" ],
      "settings": { "foreground": "#6EC9A8" }
    },
    {
      "name": "Python - f-string interpolation braces",
      "scope": [
        "constant.character.format.placeholder.other.python",
        "punctuation.definition.interpolation.begin.python",
        "punctuation.definition.interpolation.end.python"
      ],
      "settings": { "foreground": "#D291FF" }
    },
    {
      "name": "Python - docstrings",
      "scope": [
        "string.quoted.docstring.multi.python",
        "string.quoted.docstring.raw.multi.python"
      ],
      "settings": { "foreground": "#5C6370", "fontStyle": "italic" }
    },
    {
      "name": "Python - magic/dunder methods",
      "scope": [ "support.function.magic.python" ],
      "settings": { "foreground": "#E5D0A1" }
    },
    {
      "name": "Python - walrus operator :=",
      "scope": [ "keyword.operator.walrus.python" ],
      "settings": { "foreground": "#ABB2BF" }
    },

    // ─── JavaScript / TypeScript ──────────────────────────────────────────────
    {
      "name": "JS/TS - this",
      "scope": [
        "variable.language.this.js",
        "variable.language.this.ts",
        "variable.language.this.jsx",
        "variable.language.this.tsx"
      ],
      "settings": { "foreground": "#61AFEF" }
    },
    {
      "name": "JS/TS - arrow function =>",
      "scope": [
        "storage.type.function.arrow.js",
        "storage.type.function.arrow.ts",
        "storage.type.function.arrow.jsx",
        "storage.type.function.arrow.tsx"
      ],
      "settings": { "foreground": "#61AFEF" }
    },
    {
      "name": "JS/TS - optional chaining ?.",
      "scope": [
        "keyword.operator.optional.js",
        "keyword.operator.optional.ts",
        "punctuation.accessor.optional.js",
        "punctuation.accessor.optional.ts"
      ],
      "settings": { "foreground": "#ABB2BF" }
    },
    {
      "name": "TypeScript - type annotations and generics",
      "scope": [
        "meta.type.annotation.ts",
        "meta.type.annotation.tsx",
        "meta.return.type.ts",
        "meta.return.type.tsx",
        "meta.type.parameters.ts",
        "meta.type.parameters.tsx"
      ],
      "settings": { "foreground": "#6EC9A8" }
    },
    {
      "name": "TypeScript - built-in types (string, number, boolean, any, void)",
      "scope": [
        "support.type.builtin.ts",
        "support.type.builtin.tsx",
        "keyword.type.ts",
        "keyword.type.tsx"
      ],
      "settings": { "foreground": "#6EC9A8" }
    },
    {
