    "struct": "#6EC9A8",
    "typeParameter": "#6EC9A8",
    "enum": "#6EC9A8",
    "enumMember": "#98C379",
    "function": "#E5D0A1",
    "function.declaration": "#E5D0A1",
    "method": "#E5D0A1",
    "method.declaration": "#E5D0A1",
    "member": "#E5D0A1",
    "property.declaration": "#E5D0A1",
    "string": "#D19A66",
    "number": "#98C379",
    "variable": "#B0E0E6",
    "parameter": { "foreground": "#B0E0E6", "italic": true },
    "property": "#B0E0E6",
    "property.readonly": "#B0E0E6",
    "namespace": "#6EC9A8",
    "module": "#6EC9A8",
    "comment": { "foreground": "#5C6370", "italic": true },
    "comment.documentation": { "foreground": "#5C6370", "italic": true },
    "operator": "#D9E0EE",
    "punctuation": "#ABB2BF",
    "macro": "#61AFEF",
    "builtinType": "#6EC9A8",
    "selfKeyword": "#61AFEF",
    "selfParameter": "#B0E0E6",
    "clsParameter": "#B0E0E6",
    "decorator": "#C678DD",
    "annotation": "#C678DD",
    "attribute": "#C678DD",
    "lifetime": "#C678DD",
    "label": "#C678DD",
    "formatSpecifier": "#C678DD",
    "escapeSequence": "#E5C07B",
    "modifier": { "foreground": "#61AFEF", "italic": true },
    "unresolvedReference": { "foreground": "#E06C75", "underline": true },
    "*.deprecated": { "strikethrough": true },

    // Python-specific
    "selfParameter:python": { "foreground": "#B0E0E6", "italic": true },
    "clsParameter:python": { "foreground": "#B0E0E6", "italic": true },

    // Rust-specific
    "*.unsafe": { "foreground": "#D291FF", "italic": true },
    "*.unsafe:rust": { "foreground": "#D291FF", "italic": true },
    "*.mutable:rust": { "underline": true },
    "lifetime:rust": { "foreground": "#C678DD" },
    "builtinAttribute:rust": { "foreground": "#C678DD" },
    "derive:rust": { "foreground": "#C678DD" }
  }
